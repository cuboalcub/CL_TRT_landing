<section class="content-section coverage-section" id="sucursales">
    <div class="section-shell">
        <div class="coverage-header">
            <p class="section-kicker">Sedes y cobertura</p>
            <h2>Presencia estratégica en zonas clave</h2>
            <p class="section-description">
                Capacidad logística optimizada en centros industriales de alta
                demanda. Identifica la sede que atiende tu región para una
                respuesta inmediata.
            </p>
        </div>

        <div class="coverage-grid">
            <!-- CDMX -->
            <article class="cov-card active">
                <div class="cov-card-header">
                    <div class="cov-indicator glow-green"></div>
                    <h3>CDMX & Área Metropolitana</h3>
                    <span class="cov-badge">Sede Tlalnepantla</span>
                </div>
                <div class="cov-card-body">
                    <p class="cov-desc">
                        <strong>Cobertura total</strong> en toda la CDMX y municipios
                        conurbados del Edomex. Entregas el mismo día.
                    </p>
                </div>
            </article>

            <!-- Veracruz -->
            <article class="cov-card active">
                <div class="cov-card-header">
                    <div class="cov-indicator glow-green"></div>
                    <h3>Orizaba y Rio Blanco</h3>
                    <span class="cov-badge">Sede Centro</span>
                </div>
                <div class="cov-card-body">
                    <p class="cov-desc">
                        <strong>Radio de 50 km</strong> (Boca del Río, Alvarado y
                        alrededores). Envíos foráneos al resto del estado por paquetería.
                    </p>
                </div>
            </article>
        </div>
    </div>
</section>

<style>
    /* --- Coverage Section --- */
    .coverage-section {
        background-color: var(--color-surface-dark);
        color: white;
        padding: var(--section-padding) 0;
    }

    .coverage-header {
        max-width: 700px;
        margin-bottom: 56px;
    }

    .coverage-section h2 {
        color: var(--color-text-light);
        font-size: clamp(2rem, 4vw, 2.8rem);
        line-height: 1.15;
        margin-bottom: 24px;
    }

    .coverage-section .section-kicker {
        color: var(--color-accent-primary);
        margin-bottom: 16px;
    }

    .section-description {
        font-size: 1.1rem;
        color: rgba(255, 255, 255, 0.7);
        line-height: 1.6;
    }

    .coverage-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 32px;
    }

    .cov-card {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        padding: 32px;
        transition: all 0.3s var(--motion-easing-default);
        position: relative;
        overflow: hidden;
        backdrop-filter: blur(12px);
    }

    .cov-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
            135deg,
            rgba(29, 49, 129, 0.1),
            rgba(234, 88, 12, 0.1)
        );
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .cov-card:hover {
        border-color: rgba(255, 255, 255, 0.25);
        transform: translateY(-8px);
        background: rgba(255, 255, 255, 0.08);
    }

    .cov-card:hover::before {
        opacity: 1;
    }

    .cov-card.upcoming {
        border-style: dashed;
        opacity: 0.8;
    }

    .cov-card-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .cov-indicator {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .glow-green {
        background: #10b981;
        box-shadow: 0 0 15px rgba(16, 185, 129, 0.4);
    }
    .glow-orange {
        background: #f59e0b;
        box-shadow: 0 0 15px rgba(245, 158, 11, 0.4);
    }

    .cov-card h3 {
        font-size: 1.25rem;
        color: #fff;
        margin: 0;
        line-height: 1.2;
        flex: 1;
        min-width: 180px;
    }

    .cov-badge {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding: 6px 12px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 100px;
        color: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(255, 255, 255, 0.2);
        font-weight: 700;
    }

    .cov-desc {
        color: rgba(255, 255, 255, 0.75);
        font-size: 1rem;
        margin-bottom: 24px;
        line-height: 1.6;
    }

    .cov-card strong {
        color: #ffffff;
    }

    .cov-actions .btn-text {
        color: #ffffff;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.85rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s;
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 100px;
        padding: 12px 20px;
        background: rgba(255, 255, 255, 0.05);
    }

    .cov-actions .btn-text:hover {
        background: white;
        color: var(--color-brand-primary);
        border-color: white;
    }

    .cov-actions .btn-text-muted {
        opacity: 0.5;
        cursor: not-allowed;
    }

    @media (max-width: 640px) {
        .coverage-grid {
            grid-template-columns: 1fr;
        }

        .cov-card {
            padding: 24px;
        }
    }
</style>
