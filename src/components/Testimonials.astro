<section class="content-section testimonial-section">
    <div class="section-shell relative-content">
        <p class="section-kicker">Clientes y testimonios</p>
        <h2>Confianza que se traduce en recompra</h2>
        
        <div class="testimonial-carousel reveal-stagger">
            <article class="testimonial-card-outer double-bezel-outer-light">
                <div class="testimonial-card-inner double-bezel-inner-light">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="testimonial-quote-icon"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1.5.5 1.5 1.5L5 21zm12 0c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1.5.5 1.5 1.5L17 21z"></path></svg>
                    <p>"Nos resolvieron una urgencia de rodamientos el mismo día."</p>
                    <div class="testimonial-author">
                        <div class="testimonial-avatar">TN</div>
                        <div class="testimonial-author-info">
                            <span>Taller Industrial Norte</span>
                            <small>Cliente recurrente</small>
                        </div>
                    </div>
                </div>
            </article>
            
            <article class="testimonial-card-outer double-bezel-outer-light">
                <div class="testimonial-card-inner double-bezel-inner-light">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="testimonial-quote-icon"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1.5.5 1.5 1.5L5 21zm12 0c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1.5.5 1.5 1.5L17 21z"></path></svg>
                    <p>"Cotización muy rápida y la pieza llegó exacta."</p>
                    <div class="testimonial-author">
                        <div class="testimonial-avatar">MR</div>
                        <div class="testimonial-author-info">
                            <span>Mantenimiento Rivera</span>
                            <small>Volumen industrial</small>
                        </div>
                    </div>
                </div>
            </article>
            
            <article class="testimonial-card-outer double-bezel-outer-light">
                <div class="testimonial-card-inner double-bezel-inner-light">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="testimonial-quote-icon"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1.5.5 1.5 1.5L5 21zm12 0c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1.5.5 1.5 1.5L17 21z"></path></svg>
                    <p>"Compramos por volumen cada mes y cumplen tiempos."</p>
                    <div class="testimonial-author">
                        <div class="testimonial-avatar">FC</div>
                        <div class="testimonial-author-info">
                            <span>Flotillas del Centro</span>
                            <small>Flotilla logística</small>
                        </div>
                    </div>
                </div>
            </article>
            
            <article class="testimonial-card-outer double-bezel-outer-light">
                <div class="testimonial-card-inner double-bezel-inner-light">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="testimonial-quote-icon"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1.5.5 1.5 1.5L5 21zm12 0c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1.5.5 1.5 1.5L17 21z"></path></svg>
                    <p>"Aunque fui particular, me asesoraron muy bien."</p>
                    <div class="testimonial-author">
                        <div class="testimonial-avatar">CP</div>
                        <div class="testimonial-author-info">
                            <span>Cliente particular, CDMX</span>
                            <small>Compra unitaria</small>
                        </div>
                    </div>
                </div>
            </article>
        </div>
    </div>
</section>

<style>
/* Testimonial Section (Light Theme & Carousel) */
.testimonial-section {
    background: #f5f4f1 !important;
    border-top: none !important;
    border-bottom: 1px solid #e5e7eb;
    padding: var(--section-padding) 0;
    overflow: hidden;
}

.testimonial-section .section-kicker {
    color: var(--color-accent-primary);
}

.testimonial-section h2 {
    color: var(--color-brand-primary);
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin-bottom: 40px;
    letter-spacing: -0.02em;
}

.testimonial-carousel {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    padding-bottom: 32px;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
}

.testimonial-carousel::-webkit-scrollbar {
    display: none;
}

.testimonial-card-outer {
    flex: 0 0 85%;
    max-width: 400px;
    scroll-snap-align: center;
}

@media (min-width: 768px) {
    .testimonial-card-outer {
        flex: 0 0 calc(50% - 12px);
        scroll-snap-align: start;
    }
}

@media (min-width: 1024px) {
    .testimonial-card-outer {
        flex: 0 0 calc(33.333% - 16px);
    }
}

.testimonial-card-inner {
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    text-align: left;
}

.testimonial-quote-icon {
    color: var(--color-accent-primary);
    margin-bottom: 20px;
    opacity: 0.3;
}

.testimonial-card-inner p {
    font-size: 1.1rem;
    color: #334155;
    line-height: 1.6;
    margin-bottom: 32px;
    font-weight: 500;
}

.testimonial-author {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: auto;
}

.testimonial-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(29, 49, 129, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-brand-primary);
    font-weight: 800;
    font-size: 1.1rem;
    letter-spacing: 0.05em;
}

.testimonial-author-info {
    display: flex;
    flex-direction: column;
}

.testimonial-author-info span {
    color: var(--color-brand-primary);
    font-weight: 800;
    font-size: 1rem;
    line-height: 1.2;
}

.testimonial-author-info small {
    color: #64748b;
    font-size: 0.85rem;
    margin-top: 4px;
}
</style>
