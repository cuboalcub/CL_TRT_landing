---
import { Image } from "astro:assets";
import catalogPreview from "../assets/catalog-preview.png";
import catalogGeneral from "../assets/Catalogo2026.pdf";
---

<section class="content-section catalog-section" id="catalogos">
    <div class="section-shell relative-content">
        <p class="section-kicker">INGENIERÍA EN MOVIMIENTO</p>
        <h2>Catálogos por Línea</h2>
        <p class="section-description">
            Explora nuestras soluciones técnicas de alta precisión. Descarga la
            ficha técnica o solicita una cotización inmediata.
        </p>

        <div class="catalog-single-wrapper">
            <!-- CARD: Catálogo General -->
            <article class="catalog-card-outer double-bezel-outer-light">
                <div class="catalog-card-inner double-bezel-inner-light">
                    <div class="catalog-visual">
                        <Image
                            src={catalogPreview}
                            alt="Vista previa del Catálogo TRT 2025"
                            class="catalog-img"
                        />
                        <div class="catalog-overlay">
                            <span class="tech-id">SPEC-TRT-2025</span>
                        </div>
                    </div>
                    <div class="catalog-content">
                        <div class="catalog-header">
                            <h3>Catálogo General de Productos</h3>
                            <span class="catalog-badge">Premium</span>
                        </div>
                        <p>
                            Líneas completas de Rodamientos, Bandas, Cadenas y
                            Transmisión de Potencia.
                        </p>
                        <div class="catalog-specs">
                            <div class="spec-item">
                                <span class="spec-label">LÍNEAS</span>
                                <span class="spec-value">+20</span>
                            </div>
                            <div class="spec-item">
                                <span class="spec-label">REV</span>
                                <span class="spec-value">2026.05</span>
                            </div>
                        </div>
                    </div>
                    <div class="catalog-footer">
                        <a href={catalogGeneral} download class="btn--pdf-full">
                            <svg
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                width="18"
                                height="18"
                                aria-hidden="true"
                                ><path
                                    d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
                                ></path><polyline points="7 10 12 15 17 10"
                                ></polyline><line x1="12" y1="15" x2="12" y2="3"
                                ></line></svg
                            >
                            Descargar Ficha PDF
                        </a>
                    </div>
                </div>
            </article>
        </div>
    </div>
</section>

<style>
    /* NEW: Catalog Section Styles */
    .catalog-section {
        background: #f5f4f1 !important;
        border-top: none !important;
        border-bottom: 1px solid #e5e7eb;
        padding: var(--section-padding) 0;
    }

    .catalog-section .section-kicker {
        color: var(--color-accent-primary);
    }

    .catalog-section h2 {
        font-size: clamp(2rem, 4vw, 2.8rem);
        margin-bottom: 20px;
        letter-spacing: -0.02em;
        color: var(--color-brand-primary);
    }

    .catalog-section .section-description {
        color: rgba(15, 23, 42, 0.85);
        margin-bottom: 56px;
        font-size: 1.15rem;
        font-weight: 500;
        max-width: 55ch;
        text-align: left;
        margin-left: 0;
    }

    .catalog-single-wrapper {
        display: flex;
        justify-content: center;
        max-width: 450px;
        margin: 0 auto;
    }

    .btn--pdf-full {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        width: 100%;
        padding: 14px;
        background: var(--color-brand-primary);
        color: white;
        text-decoration: none;
        font-weight: 700;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

    .btn--pdf-full:hover {
        background: var(--color-brand-accent);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(234, 88, 12, 0.2);
    }

    .double-bezel-outer-light:hover {
        border-color: var(--color-action-primary-default);
        transform: translateY(-5px);
        box-shadow: 0 16px 30px rgba(29, 49, 129, 0.12);
    }

    .double-bezel-outer-light:hover .double-bezel-inner-light {
        background: #ffffff;
    }

    .catalog-visual {
        height: 220px;
        position: relative;
        overflow: hidden;
        background: #f1f5f9;
    }

    .catalog-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s var(--motion-easing-default);
        filter: brightness(0.95) contrast(1.05);
    }

    .double-bezel-outer-light:hover .catalog-img {
        transform: scale(1.05);
        filter: brightness(1) contrast(1.1);
    }

    .catalog-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to bottom,
            rgba(0, 0, 0, 0) 50%,
            rgba(0, 0, 0, 0.8) 100%
        );
        display: flex;
        align-items: flex-end;
        padding: 16px;
    }

    .tech-id {
        font-family: "Courier New", Courier, monospace;
        font-size: 0.75rem;
        font-weight: 700;
        color: #ffffff;
        background: rgba(0, 0, 0, 0.6);
        padding: 4px 8px;
        border-radius: 4px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        letter-spacing: 0.1em;
    }

    .catalog-content {
        padding: 24px;
        flex-grow: 1;
    }

    .catalog-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 12px;
    }

    .catalog-header h3 {
        font-size: 1.25rem;
        color: var(--color-brand-primary);
        font-weight: 800;
        letter-spacing: -0.01em;
    }

    .catalog-badge {
        font-size: 0.6rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 4px 8px;
        background: rgba(15, 23, 42, 0.05);
        color: var(--color-brand-primary);
        border-radius: 4px;
        border: 1px solid rgba(15, 23, 42, 0.1);
    }

    .catalog-content p {
        font-size: 0.9rem;
        color: rgba(15, 23, 42, 0.65);
        line-height: 1.6;
        margin-bottom: 24px;
    }

    .catalog-specs {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        border-top: 1px solid rgba(15, 23, 42, 0.08);
        padding-top: 20px;
    }

    .spec-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .spec-label {
        font-size: 0.65rem;
        font-weight: 800;
        color: rgba(15, 23, 42, 0.4);
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .spec-value {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--color-brand-accent);
    }

    .catalog-footer {
        padding: 0 24px 24px;
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 12px;
    }

    @media (max-width: 980px) {
        .catalog-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 640px) {
        .catalog-grid {
            grid-template-columns: 1fr;
        }

        .catalog-visual {
            height: 180px;
        }
    }
</style>
