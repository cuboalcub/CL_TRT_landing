<section class="content-section diferencial-section">
    <div class="section-shell">
        <p class="section-kicker">Por qué TRT</p>
        <h2>Diferenciadores reales</h2>

        <!-- PRIMARY DIFFERENTIATORS -->
        <div class="feature-grid primary">
            <article class="featured-primary">
                <div class="feature-icon feature-icon--orange">
                    <svg
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path
                            d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"
                        ></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"
                        ></polyline><line x1="12" y1="22.08" x2="12" y2="12"
                        ></line></svg
                    >
                </div>
                <h3>Stock el mismo día</h3>
                <p>
                    Resolvemos urgencias de taller sin demoras. Inventario
                    activo en CDMX y Veracruz disponible inmediatamente.
                </p>
            </article>
            <article class="featured-primary">
                <div class="feature-icon feature-icon--orange">
                    <svg
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><polygon
                            points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"
                        ></polygon></svg
                    >
                </div>
                <h3>Cotización</h3>
                <p>
                    No esperes 24-48 horas. Validamos existencia y opciones
                    equivalentes.
                </p>
            </article>
        </div>

        <!-- SECONDARY BENEFITS -->
        <div class="feature-grid secondary">
            <article>
                <div class="feature-icon feature-icon--blue">
                    <svg
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path
                            d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"
                        ></path></svg
                    >
                </div>
                <h3>Asesoría técnica incluida</h3>
                <p>
                    Te ayudamos a cruzar medidas y encontrar equivalencias entre
                    marcas.
                </p>
            </article>
        </div>

        <div class="stats-row">
            <div><strong>20+</strong><span>Años de experiencia</span></div>
            <div><strong>50,000+</strong><span>Piezas en stock</span></div>
            <div>
                <strong>100%</strong><span>Garantia de satisfacción</span>
            </div>
        </div>
    </div>
</section>

<style>
    /* Diferenciadores Section (Light Theme) */
    .diferencial-section {
        background: #f5f4f1 !important;
        border-top: none !important;
        border-bottom: 1px solid #e5e7eb;
        padding: var(--section-padding) 0;
    }

    .diferencial-section .section-kicker {
        color: var(--color-accent-primary);
    }

    .diferencial-section h2 {
        color: var(--color-brand-primary);
        font-size: clamp(2rem, 4vw, 2.8rem);
        margin-bottom: 40px;
        letter-spacing: -0.02em;
    }

    .feature-grid {
        display: grid;
        gap: 18px;
    }

    .feature-grid.primary {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        margin-bottom: 32px;
    }

    .feature-grid.secondary {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .diferencial-section .feature-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        border-radius: 12px;
        margin-bottom: 20px;
    }

    .diferencial-section .feature-icon--orange {
        background: rgba(234, 88, 12, 0.1);
        color: var(--color-accent-primary);
    }

    .diferencial-section .feature-icon--blue {
        background: rgba(29, 49, 129, 0.06);
        color: var(--color-brand-primary);
    }

    .diferencial-section .featured-primary,
    .diferencial-section .feature-grid.secondary article {
        background: #ffffff !important;
        border: 1px solid rgba(15, 23, 42, 0.08) !important;
        box-shadow: 0 4px 16px rgba(15, 23, 42, 0.03) !important;
        border-radius: 16px;
        padding: 32px 24px;
        transition: all 0.4s var(--motion-easing-default);
    }

    .diferencial-section .featured-primary:hover,
    .diferencial-section .feature-grid.secondary article:hover {
        box-shadow: 0 16px 32px rgba(15, 23, 42, 0.08) !important;
        transform: translateY(-4px);
        border-color: rgba(15, 23, 42, 0.15) !important;
    }

    .diferencial-section .featured-primary h3,
    .diferencial-section .feature-grid.secondary h3 {
        color: var(--color-brand-primary) !important;
        font-size: 1.25rem;
        font-weight: 700;
        margin-bottom: 12px;
    }

    .diferencial-section .featured-primary p,
    .diferencial-section .feature-grid.secondary p {
        color: #475569 !important;
        font-size: 0.95rem;
        line-height: 1.6;
    }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
        margin-top: 40px;
    }

    .stats-row div {
        background: #ffffff;
        border: 1px solid rgba(29, 49, 129, 0.15);
        box-shadow: 0 12px 26px rgba(15, 23, 42, 0.05);
        border-radius: 14px;
        padding: 18px;
    }

    .stats-row strong {
        display: block;
        color: var(--color-brand-primary);
        font-size: 1.7rem;
        line-height: 1;
    }

    .stats-row span {
        color: #475569;
        font-size: 0.9rem;
    }

    @media (max-width: 980px) {
        .feature-grid.primary,
        .feature-grid.secondary,
        .stats-row {
            grid-template-columns: 1fr;
        }
    }
</style>
