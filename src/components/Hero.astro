<section class="hero-section cinematic-full">
    <!-- Background Image with Scrim & Technical Grid -->
    <div class="hero-visual-bg">
        <div class="hero-blueprint-grid"></div>
        <img
            src="assets/img/hero-image.jpeg"
            alt="Almacén TRT"
            class="bg-img"
        />
        <div class="bg-scrim"></div>
    </div>

    <div class="hero-container-full">
        <!-- Content Area -->
        <div class="hero-content-left">
            <div class="reveal-stagger">
                <div class="hero-brand-tag">
                    <div class="hero-stats-badge">20+ Años de Trayectoria</div>
                </div>

                <h1 class="hero-headline-cinematic">
                    La Red de <span class="text-accent">Refacciones</span><br />
                    con +50,000 piezas en stock.
                </h1>

                <p class="hero-subheadline-cinematic">
                    Disponibilidad en CDMX y Veracruz para talleres, flotillas y
                    particulares. Cotizamos cualquier pieza en <strong></strong>
                </p>

                <div class="hero-actions-cinematic">
                    <a
                        href="#contacto"
                        class="btn--whatsapp"
                        aria-label="Cotizar por WhatsApp"
                    >
                        <svg
                            class="btn__icon"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            aria-hidden="true"
                        >
                            <path
                                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.966-.273-.099-.471-.148-.67.15-.198.297-.768.965-.94 1.164-.173.198-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.787-1.48-1.76-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.151-.173.2-.298.3-.497.099-.198.05-.371-.025-.52-.074-.148-.669-1.612-.916-2.207-.242-.58-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.793.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.148.198 2.095 3.2 5.077 4.487.71.306 1.263.489 1.694.626.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.414.248-.694.248-1.29.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.002-5.448 4.436-9.883 9.887-9.883 2.64 0 5.122 1.03 6.988 2.899 1.868 1.868 2.9 4.352 2.899 6.991-.003 5.45-4.437 9.885-9.89 9.885"
                            ></path>
                        </svg>
                        Cotizar por WhatsApp
                    </a>
                    <a href="#catalogos" class="btn--ghost-dark">Ver Catálogo</a
                    >
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    /* --- 2.1 Hero Section (Cinematic Full-Bleed) --- */
    .hero-section.cinematic-full {
        min-height: 100vh;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        padding-top: 96px;
        padding-bottom: 84px;
        box-sizing: border-box;
        background-color: var(--color-surface-dark);
    }

    .hero-visual-bg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
    }

    .bg-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: saturate(0.8) brightness(0.9);
    }

    .bg-scrim {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(
            105deg,
            rgba(0, 0, 0, 0.65) 0%,
            rgba(0, 0, 0, 0.35) 50%,
            rgba(0, 0, 0, 0.1) 100%
        );
    }

    .hero-blueprint-grid {
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
            linear-gradient(
                90deg,
                rgba(255, 255, 255, 0.03) 1px,
                transparent 1px
            );
        background-size: 40px 40px;
        z-index: 2;
        mask-image: radial-gradient(circle at 20% 50%, black, transparent 80%);
        pointer-events: none;
    }

    .hero-container-full {
        width: 100%;
        padding: 0 var(--page-gutter);
        position: relative;
        z-index: 10;
    }

    .hero-content-left {
        max-width: 760px;
        position: relative;
        padding: var(--space-6) 0;
    }

    .hero-brand-tag {
        display: flex;
        align-items: center;
        gap: var(--space-4);
        margin-bottom: var(--space-4);
    }

    .hero-stats-badge {
        background: var(
            --color-action-primary
        ); /* Fondo azul sólido para alto contraste */
        color: white;
        font-size: 0.75rem; /* font-xs */
        font-weight: 800;
        padding: 6px 12px;
        border-radius: 100px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border: none;
        box-shadow: 0 3px 12px rgba(8, 12, 24, 0.28);
    }

    .hero-headline-cinematic {
        font-size: clamp(2.2rem, 4.4vw, 4rem);
        font-weight: 900;
        line-height: 1.08;
        letter-spacing: -0.02em;
        color: rgba(255, 255, 255, 0.94);
        margin-bottom: var(--space-4);
        text-transform: none;
        text-shadow: 0 2px 20px rgba(0, 0, 0, 0.4);
    }

    .text-accent {
        color: #ffffff;
        text-shadow: 0 2px 14px rgba(0, 0, 0, 0.45);
    }

    .hero-subheadline-cinematic {
        font-size: 1.06rem;
        color: rgba(255, 255, 255, 0.9);
        max-width: 58ch;
        line-height: 1.55;
        margin-bottom: var(--space-6);
        text-shadow: 0 2px 6px rgba(0, 0, 0, 0.18);
    }

    .hero-actions-cinematic {
        display: flex;
        gap: var(--space-6);
        margin-top: var(--space-6);
    }

    @media (max-width: 768px) {
        .bg-scrim {
            background: linear-gradient(
                0deg,
                rgba(0, 0, 0, 0.9) 18%,
                rgba(0, 0, 0, 0.53) 100%
            );
        }
        .hero-container-full {
            padding: 0 var(--page-gutter);
        }
        .hero-headline-cinematic {
            font-size: clamp(2rem, 10vw, 3rem);
        }
        .hero-subheadline-cinematic {
            font-size: 1rem;
        }
        .hero-brand-tag {
            flex-direction: column;
            align-items: flex-start;
            gap: 8px;
        }
        .hero-actions-cinematic {
            flex-direction: column;
            gap: 16px;
        }
    }
</style>
